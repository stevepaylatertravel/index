  /* Sliders */
  .slider-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem 2rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 520px) {
    .slider-grid { grid-template-columns: 1fr; }
  }

  .slider-block label {
    display: flex;
    justify-content: space-between;
